    width: 160px;
    height: 60px;
  }
  #ia895 {
    display: block;
    left: 100px;
    top: 320px;
    position: absolute;
    width: 400px;
    height: 40px;
  }
  #ia895 .noUi-touch-area { slidertouchareapadding_padding: 0px; }
  #ia895 .ch5-slider :not(i):not(svg) { font-family: Roboto; }
  #ie10e {
    display: block;
    left: 100px;
    top: 100px;
    position: absolute;
    width: 300px;
    height: 40px;
  }
  #ie10e :not(i):not(svg) { font-family: 'Roboto'; }
}
